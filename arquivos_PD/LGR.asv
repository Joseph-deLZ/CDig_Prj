s = tf('s');

Kp = 0.8864;
Tp1 = 323.16;
Tp2 = 37.636;
Td = 5;
Tz = 278.32;

Hap = (Kp*(1+Tz*s)*(1-(Td/2)*s))/((1+Tp1*s)*(1+Tp2*s)*(1+(Td/2)*s));

% Antigos (com Mp_teórica = 45%)
%K = 2.7675; 
%A = 0.1378;

K = 3.25;
A = 0.106;

G = K*(s+A)/s;

%rlocus(Hap);
%rlocus(G*Hap);

step(feedback(G*Hap, 1));